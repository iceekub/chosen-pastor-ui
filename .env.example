# Copy to .env.local. Defaults below match the local Supabase CLI stack.
# Override in production with your project's URL + keys.

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_ACJWlzQHlZjBrEguHvfOxg_3BJgxAaH

# Ragserv (sermon upload + AI pipeline)
NEXT_PUBLIC_RAGSERV_URL=http://127.0.0.1:8080

# Public-read AWS S3 bucket where MediaConvert writes auto-generated
# thumbnail frame captures. Provisioned by ragserv/terraform/buckets.tf
# (resource aws_s3_bucket.thumbnails). Set to the bucket's regional
# domain — the thumbnail picker uses this to render alternate
# auto-frame candidates from the row's thumbnail_keys array.
# In prod: https://<env>-thumbnails.s3.<region>.amazonaws.com
NEXT_PUBLIC_AWS_THUMBNAILS_BUCKET_URL=

# Server-side session encryption key — REPLACE in production with a
# random 32+ byte string.
SESSION_SECRET=dev-secret-replace-in-production
